{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "public",
  "installCommand": "echo \"No install required\"",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "avukataysenuravci.com" }],
      "destination": "https://avukataysenuravci.com.tr/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.avukataysenuravci.com" }],
      "destination": "https://avukataysenuravci.com.tr/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.avukataysenuravci.com.tr" }],
      "destination": "https://avukataysenuravci.com.tr/:path*",
      "permanent": true
    }
  ]
}
